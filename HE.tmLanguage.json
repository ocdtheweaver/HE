{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HE",
  "scopeName": "source.he",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#objects" },
    { "include": "#actions" },
    { "include": "#blocks" },
    { "include": "#loops" },
    { "include": "#conditions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.he",
          "match": "//.*$"
        },
        {
          "name": "comment.block.he",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.he",
          "match": "\\b(make|has|end|fetch|with)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.he",
          "match": "\\b(int|dec|string)\\b"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.he",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.he",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.he",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.he",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "objects": {
      "patterns": [
        {
          "name": "entity.name.type.class.he",
          "match": "\\bmake\\s+([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },

    "blocks": {
      "patterns": [
        {
          "name": "entity.name.section.block.he",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\["
        }
      ]
    },

    "actions": {
      "patterns": [
        {
          "name": "entity.name.function.he",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\("
        }
      ]
    },

    "loops": {
      "patterns": [
        {
          "name": "keyword.control.loop.he",
          "match": "\\b(repeat|run|until|while)\\b"
        }
      ]
    },

    "conditions": {
      "patterns": [
        {
          "name": "keyword.control.conditional.he",
          "match": "\\b(if|otherwise|orelse|and|or)\\b"
        }
      ]
    }
  },

  "fileTypes": ["he"],
  "uuid": "8e1c5fb8-5c11-4b07-a7e3-9d97f823be12"
}
