~ This is a main file comment ~
summon "Player" as hero

with image "assets/hero.png" named playerSprite
  ~ and sound "assets/jump.wav" ~

make Player {
    ~ Character properties ~
    hero has: [
        name is "Hero"
        health is 100 ~ starting health ~
    ]
    
    ~ Character abilities ~  
    hero can: [
        jump() [
            print "Jumping!"
            ~ Play jump animation ~
            tell playerSprite to playAnimation with "jump"
            wait 0.5 seconds
        ]
    ]
    
    on collision [
        print "Ouch!"
        health is health - 10 ~ reduce health on collision ~
    ]
}