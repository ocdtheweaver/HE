{
  "comments": {
    "lineComment": null,
    "blockComment": ["~", "~"]
  },
  "brackets": [["{","}"],["[","]"],["(",")"]],
  "autoClosingPairs": [
    {"open": "\"", "close": "\""},
    {"open": "[", "close": "]"},
    {"open": "{", "close": "}"},
    {"open": "(", "close": ")"}
  ],
  "surroundingPairs": [
    {"open": "\"", "close": "\""},
    {"open": "(", "close": ")"},
    {"open": "[", "close": "]"},
    {"open": "{", "close": "}"}
  ],
  "folding": {
    "offSide": false,
    "markers": {
      "start": "^\\s*#region\\b",
      "end": "^\\s*#endregion\\b"
    }
  }
}