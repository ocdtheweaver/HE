{
  "name": "hunterlang-he",
  "displayName": "Hunterlang (HE)",
  "description": "Syntax highlighting + Run/Debug commands for the Hunterlang HE language.",
  "version": "0.0.1",
  "publisher": "wolfhead",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:he"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "he",
        "aliases": [
          "HE",
          "hunterlang"
        ],
        "extensions": [
          ".he"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "hunterlang.runHe",
        "title": "HE: Run file"
      },
      {
        "command": "hunterlang.debugHe",
        "title": "HE: Debug file"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
