{
  "name": "he-language",
  "displayName": "Hunter's Engine Language",
  "description": "Syntax highlighting and basic language support for the Hunter's Engine (he) programming language.",
  "publisher": "ocd",
  "version": "0.0.1",
  "license": "MIT",
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "he",
        "aliases": ["HE", "he"],
        "extensions": [".he"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "he",
        "scopeName": "source.he",
        "path": "./syntaxes/HE.tmLanguage.json"
      }
    ]
  },
  "activationEvents": ["onLanguage:he"],
  "devDependencies": {
    "@vscode/vsce": "^3.7.0"
  }
}
